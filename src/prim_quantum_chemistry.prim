# Class QuantumChemistry
    # Quantum chemistry

    fn make_quantumchemistry():
        obj = {}
        obj["molecules"] = {}

    fn quantumchemistry_add_molecule(obj, molecule):
        # Add molecule
        obj["molecules"][molecule.name] = molecule

    def calculate_energy(self, name: str) :
        # Calculate energy
        if name in obj["molecules"]:
            return -13.6
        return null


fn main():
    print("Testing Quantum Chemistry...")
    chem = QuantumChemistry()
    molecule = Molecule(name="H2", type=MoleculeType.DIATOMIC, atoms=["H", "H"])
    chem.add_molecule(molecule)
    energy = chem.calculate_energy("H2")
    print("Energy: {energy}")
