#mode slim
# Prim Package Registry
# Provides centralized package repository with semantic versioning,
# dependency resolution, package metadata, security scanning, and private packages

# Package type constants
PACKAGE_LIBRARY = "library"
PACKAGE_FRAMEWORK = "framework"
PACKAGE_TOOL = "tool"
PACKAGE_EXAMPLE = "example"

# PackageVersion factory
fn make_package_version(version, dependencies, files, checksum, size, release_date, changelog):
    if dependencies == None:
        dependencies = {}
    if files == None:
        files = []
    if checksum == None:
        checksum = ""
    if size == None:
        size = 0
    if release_date == None:
        release_date = ""
    if changelog == None:
        changelog = ""
    return {
        "version": version,
        "dependencies": dependencies,
        "files": files,
        "checksum": checksum,
        "size": size,
        "release_date": release_date,
        "changelog": changelog
    }

# PackageMetadata factory
fn make_package_metadata(name, description, author, license, repository, homepage, keywords, package_type, versions, latest_version, downloads, rating, security_score):
    if keywords == None:
        keywords = []
    if package_type == None:
        package_type = PACKAGE_LIBRARY
    if versions == None:
        versions = {}
    if latest_version == None:
        latest_version = ""
    if downloads == None:
        downloads = 0
    if rating == None:
        rating = 0.0
    if security_score == None:
        security_score = 0.0
    return {
        "name": name,
        "description": description,
        "author": author,
        "license": license,
        "repository": repository,
        "homepage": homepage,
        "keywords": keywords,
        "package_type": package_type,
        "versions": versions,
        "latest_version": latest_version,
        "downloads": downloads,
        "rating": rating,
        "security_score": security_score
    }

# Dependency factory
fn make_dependency(name, version_constraint, optional):
    if optional == None:
        optional = false
    return {
        "name": name,
        "version_constraint": version_constraint,
        "optional": optional
    }

# SecurityReport factory
fn make_security_report(package_name, version, vulnerabilities, security_score, scan_date):
    if vulnerabilities == None:
        vulnerabilities = []
    if security_score == None:
        security_score = 0.0
    if scan_date == None:
        scan_date = ""
    return {
        "package_name": package_name,
        "version": version,
        "vulnerabilities": vulnerabilities,
        "security_score": security_score,
        "scan_date": scan_date
    }

