HTTPMethod_GET = "GET"
HTTPMethod_POST = "POST"
HTTPMethod_PUT = "PUT"
HTTPMethod_DELETE = "DELETE"
HTTPMethod_PATCH = "PATCH"
HTTPMethod_HEAD = "HEAD"
HTTPMethod_OPTIONS = "OPTIONS"HTTPStatus_OK = 200
